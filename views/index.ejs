<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Information Management</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header>
      <h1>Student Information Management</h1>
      <nav>
        <a href="/">Home</a>
        <a href="/add">Register Student</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <h2>Manage student records easily</h2>
        <p>Create, view, update, and delete student data with cloud-ready Node.js.</p>
      </section>

      <% if (error) { %>
      <div class="alert error"><%= error %></div>
      <% } %>

      <section class="table-section">
        <div class="table-header">
          <h3>All Students</h3>
          <a class="button" href="/add">Add Student</a>
        </div>
        <table>
          <thead>
            <tr>
              <th>Student ID</th>
              <th>Full Name</th>
              <th>Course</th>
              <th>Year Level</th>
              <th>Email</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (students.length === 0) { %>
            <tr>
              <td colspan="6">No student records found.</td>
            </tr>
            <% } else { %>
            <% students.forEach((student) => { %>
            <tr>
              <td><%= student.student_id %></td>
              <td><%= student.full_name %></td>
              <td><%= student.course %></td>
              <td><%= student.year_level %></td>
              <td><%= student.email %></td>
              <td>
                <a class="button small" href="/edit/<%= student.id %>">Edit</a>
                <form action="/delete/<%= student.id %>" method="post" class="inline-form" onsubmit="return confirm('Delete this student record?');">
                  <button type="submit" class="button danger small">Delete</button>
                </form>
              </td>
            </tr>
            <% }); %>
            <% } %>
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>
